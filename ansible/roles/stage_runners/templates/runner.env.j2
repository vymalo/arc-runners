# Injected into every job's environment by the runner. DOCKER_HOST points at
# /var/run/docker.sock (NOT the raw /run/user/<uid> path): that works in BOTH a
# container: job (where only the bind-mounted socket exists) and a host job (where
# the runner's private mount ns resolves it to the rootless socket).
XDG_RUNTIME_DIR={{ r_rtd }}
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_BUILDKIT=0
ACTIONS_RUNNER_HOOK_JOB_COMPLETED={{ bootstrap_dir }}/job-completed-cleanup.sh
